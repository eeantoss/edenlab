# EdenLab Cloud Configuration
# 复制此文件为 .env 并填入你的配置

# EdenLab 部署地址
# 本地开发: http://localhost:3000
# Vercel 部署: https://your-project.vercel.app
EDENLAB_URL=https://your-project.vercel.app

# 状态更新密钥（与 Vercel 中的 STATUS_SECRET 对应）
# 请生成一个安全的随机字符串
STATUS_SECRET=your-secret-token-change-this

# 注意：
# 1. .env 文件不会被提交到 Git
# 2. 请不要将 STATUS_SECRET 分享给他人
# 3. 在 Vercel 中设置相同的环境变量
